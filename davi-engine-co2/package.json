{
  "name": "davi-api-conversor-carbono",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "drizzle:generate": "dotenv -e .env -- drizzle-kit generate",
    "drizzle:migrate": "dotenv -e .env -- drizzle-kit migrate",
    "drizzle:migrate:test": "dotenv -e .env.test -- drizzle-kit migrate",
    "drizzle:push": "dotenv -e .env -- drizzle-kit push",
    "drizzle:studio": "dotenv -e .env -- drizzle-kit studio",
    "drizzle:seed": "dotenv -e .env -- tsnd -r tsconfig-paths/register --respawn=false src/db/drizzle/seed.ts",
    "build:check": "tsc --noEmit",
    "build": "dotenv -e .env.dev -- node build.mjs",
    "dev": "dotenv -e .env -- tsnd --respawn --clear -r tsconfig-paths/register src/core/bootstrap/launch-server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:changed": "jest --onlyChanged",
    "test:smoke": "jest -t \"@smoke\"",
    "test:unit": "jest --testPathPattern=src",
    "test:manual": "jest --testPathPattern=tests",
    "test:coverage": "jest --coverage"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1030.0",
    "@codegenie/serverless-express": "^4.17.1",
    "@prisma/client": "^7.6.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "env-var": "^7.5.0",
    "errorhandler": "^1.5.2",
    "esbuild-plugin-tsconfig-paths": "^1.0.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.9",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0",
    "ulid": "^3.0.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@types/aws-lambda": "^8.10.161",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/errorhandler": "^1.5.3",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.4",
    "glob": "^13.0.6",
    "jest": "^30.3.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}