# ============================================================
# CONFIGURACIÓN LOCAL — Fuente única de variables de entorno.
# Copiar a .env y rellenar los valores antes de ejecutar
# el script de despliegue (deploy.sh / deploy.ps1).
#
# El script replica automáticamente estas variables a:
#   - davi-engine-co2/.env.local
#   - davi-bff/davi.web-api/appsettings.Development.json
# ============================================================

# ── PostgreSQL (instalado localmente) ───────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_DB=CO3
POSTGRES_PASSWORD=123456

# ── Engine (davi-engine-co2) ────────────────────────────────
ENGINE_PORT=3000
# Orígenes CORS permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5000,http://localhost:4200

# ── BFF (.NET) ──────────────────────────────────────────────
BFF_PORT=5000
